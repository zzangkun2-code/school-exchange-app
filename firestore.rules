rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function validProgramType(value) {
      return value in ["online", "fieldTrip", "invitation"];
    }

    function schoolEditableFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "partnerInfo",
        "theme",
        "isFirstLogin",
        "mustChangePassword",
        "updatedAt"
      ]);
    }

    match /admins/{adminId} {
      allow read: if isOwner(adminId) || isAdmin();
      allow write: if isAdmin();
    }

    match /faqs/{faqId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /schools/{schoolId} {
      allow read: if isOwner(schoolId) || isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isOwner(schoolId) && schoolEditableFieldsOnly());

      match /schedules/{scheduleId} {
        allow read: if isOwner(schoolId) || isAdmin();
        allow create: if validProgramType(request.resource.data.type)
          && (
            isAdmin()
            || (isOwner(schoolId) && request.resource.data.ownerUid == request.auth.uid)
          );
        allow update, delete: if isAdmin()
          || (isOwner(schoolId) && resource.data.ownerUid == request.auth.uid);
      }

      match /media/{mediaId} {
        allow read: if isOwner(schoolId) || isAdmin();
        allow create: if validProgramType(request.resource.data.type)
          && (
            isAdmin()
            || (isOwner(schoolId) && request.resource.data.ownerUid == request.auth.uid)
          );
        allow update, delete: if isAdmin()
          || (isOwner(schoolId) && resource.data.ownerUid == request.auth.uid);
      }

      match /videoLinks/{docId} {
        allow read: if isOwner(schoolId) || isAdmin();
        allow create, update: if request.resource.data.urls is list
          && request.resource.data.urls.size() <= 5
          && (
            isAdmin()
            || (isOwner(schoolId) && request.resource.data.ownerUid == request.auth.uid)
          );
        allow delete: if isAdmin()
          || (isOwner(schoolId) && resource.data.ownerUid == request.auth.uid);
      }
    }

    match /{path=**}/schedules/{scheduleId} {
      allow read: if isAdmin();
    }

    match /{path=**}/media/{mediaId} {
      allow read: if isAdmin();
    }

    match /{path=**}/videoLinks/{docId} {
      allow read: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
